		{
			"key": "gateway_url",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "nlp_url",
			"value": "http://localhost:8001",
			"type": "string"
		},
		{
			"key": "graph_url",
			"value": "http://localhost:3001",
			"type": "string"
		},
		{
			"key": "notification_url",
			"value": "http://localhost:3002",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "your-user-id",
			"type": "string"
		},
		{
