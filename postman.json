{
	"info": {
		"_postman_id": "8f6e9410-3254-4960-8b6b-34f4ea469d66",
		"name": "SkillGraph API (Docker)",
		"description": "Collection of all available API endpoints in SkillGraph, mapped to Docker host ports.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Gateway (Port 3000)",
			"item": [
				{
					"name": "Auth",
					"item": [
						{
							"name": "GitHub Login",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{gateway_url}}/api/auth/github",
									"host": ["{{gateway_url}}"],
									"path": ["api", "auth", "github"]
								}
							}
						},
						{
							"name": "Google Login",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{gateway_url}}/api/auth/google",
									"host": ["{{gateway_url}}"],
									"path": ["api", "auth", "google"]
								}
							}
						},
						{
							"name": "Register",
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\",\n    \"fullName\": \"Test User\"\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{gateway_url}}/api/auth/register",
									"host": ["{{gateway_url}}"],
									"path": ["api", "auth", "register"]
								}
							}
						},
						{
							"name": "Login",
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{gateway_url}}/api/auth/login",
									"host": ["{{gateway_url}}"],
									"path": ["api", "auth", "login"]
								}
							}
						},
						{
							"name": "Me",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{gateway_url}}/api/auth/me",
									"host": ["{{gateway_url}}"],
									"path": ["api", "auth", "me"]
								}
							}
						}
					]
				},
				{
					"name": "Ingestion",
					"item": [
						{
							"name": "Trigger Ingestion",
							"request": {
								"method": "POST",
								"header": [],
								"url": {
									"raw": "{{gateway_url}}/api/ingestion/trigger",
									"host": ["{{gateway_url}}"],
									"path": ["api", "ingestion", "trigger"]
								}
							}
						},
						{
							"name": "Status",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{gateway_url}}/api/ingestion/status/:userId",
									"host": ["{{gateway_url}}"],
									"path": ["api", "ingestion", "status", ":userId"],
									"variable": [
										{
											"key": "userId",
											"value": "{{userId}}"
										}
									]
								}
							}
						}
					]
				},
				{
					"name": "Endorsements",
					"item": [
						{
							"name": "Submit",
							"request": {
								"method": "POST",
								"header": [],
								"body": {
									"mode": "raw",
									"raw": "{\n    \"studentId\": \"{{targetUserId}}\",\n    \"skillName\": \"TypeScript\",\n    \"comment\": \"Excellent coding skills\"\n}",
									"options": {
										"raw": {
											"language": "json"
										}
									}
								},
								"url": {
									"raw": "{{gateway_url}}/api/endorsements/submit",
									"host": ["{{gateway_url}}"],
									"path": ["api", "endorsements", "submit"]
								}
							}
						}
					]
				}
			]
		},
		{
			"name": "2. NLP Service (Port 8001)",
			"item": [
				{
					"name": "Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{nlp_url}}/health",
							"host": ["{{nlp_url}}"],
							"path": ["health"]
						}
					}
				},
				{
					"name": "Extract Skills",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"student_id\": \"user-123\",\n    \"repositories\": [\n        {\n            \"name\": \"test-repo\",\n            \"description\": \"python project using react\",\n            \"readme\": \"# README\",\n            \"commits\": [\"initial commit\"]\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{nlp_url}}/api/v1/nlp/extract",
							"host": ["{{nlp_url}}"],
							"path": ["api", "v1", "nlp", "extract"]
						}
					}
				},
				{
					"name": "Gazetteer Stats",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{nlp_url}}/api/v1/nlp/gazetteer/stats",
							"host": ["{{nlp_url}}"],
							"path": ["api", "v1", "nlp", "gazetteer", "stats"]
						}
					}
				}
			]
		},
		{
			"name": "3. Graph Service (Port 3001)",
			"item": [
				{
					"name": "Update Graph",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"studentId\": \"{{userId}}\",\n    \"githubHandle\": \"testuser\",\n    \"repositories\": [\n        {\n            \"id\": \"repo-1\",\n            \"name\": \"skillgraph\",\n            \"fullName\": \"user/skillgraph\",\n            \"description\": \"A project\",\n            \"language\": \"TypeScript\"\n        }\n    ],\n    \"skills\": [\n        {\n            \"skill_name\": \"TypeScript\",\n            \"confidence\": 0.9,\n            \"source_repos\": [\"skillgraph\"]\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{graph_url}}/graph/update",
							"host": ["{{graph_url}}"],
							"path": ["graph", "update"]
						}
					}
				},
				{
					"name": "Get Student Skills",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{graph_url}}/graph/student/:id/skills",
							"host": ["{{graph_url}}"],
							"path": ["graph", "student", ":id", "skills"],
							"variable": [
								{
									"key": "id",
									"value": "{{userId}}"
								}
							]
						}
					}
				},
				{
					"name": "Industry Roles",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{graph_url}}/graph/roles",
							"host": ["{{graph_url}}"],
							"path": ["graph", "roles"]
						}
					}
				}
			]
		},
		{
			"name": "4. Notification Service (Port 3002)",
			"item": [
				{
					"name": "Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{notification_url}}/health",
							"host": ["{{notification_url}}"],
							"path": ["health"]
						}
					}
				}
			]
		}
	],
	"event": [
